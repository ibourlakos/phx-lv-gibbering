# Copy to .env — defaults match compose.yaml out of the box.
# Note: DATABASE_URL uses "db" (Docker service name), not "localhost".

DATABASE_URL=ecto://gibbering:gibbering@db/gibbering_dev
SECRET_KEY_BASE=changeme_generate_with_mix_phx_gen_secret
PHX_HOST=localhost
MIX_ENV=dev

# Dev admin credentials (seeded by mix ecto.setup)
# ADMIN_EMAIL=admin@gibbering.local
# ADMIN_PASSWORD=gibbering_admin
