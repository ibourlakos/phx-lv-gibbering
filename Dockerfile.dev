FROM elixir:1.18.4-otp-27-alpine

RUN apk add --no-cache \
    build-base \
    git \
    nodejs \
    npm \
    inotify-tools \
    wget \
    unzip

RUN addgroup -S -g 1000 app && adduser -S -u 1000 -G app app

RUN mix local.hex --force && mix local.rebar --force

WORKDIR /app
RUN chown app:app /app

USER app

ARG ELIXIR_LS_VERSION=0.30.0
RUN wget -qO /tmp/elixir-ls.zip \
      "https://github.com/elixir-lsp/elixir-ls/releases/download/v${ELIXIR_LS_VERSION}/elixir-ls-v${ELIXIR_LS_VERSION}.zip" && \
    unzip -q /tmp/elixir-ls.zip -d /home/app/.elixir-ls && \
    chmod +x /home/app/.elixir-ls/language_server.sh && \
    rm /tmp/elixir-ls.zip && \
    echo "" | MIX_ENV=prod elixir /home/app/.elixir-ls/quiet_install.exs > /dev/null

# Copy umbrella root manifest and all per-app manifests before deps.get so
# Mix can resolve dependencies for the full app graph in one pass.
COPY --chown=app:app mix.exs mix.lock ./
RUN mkdir -p apps/gibbering \
             apps/gibbering_engine \
             apps/gibbering_tales \
             apps/gibbering_tales_web \
             apps/gibbering_tales_admin
COPY --chown=app:app apps/gibbering/mix.exs apps/gibbering/mix.exs
COPY --chown=app:app apps/gibbering_engine/mix.exs apps/gibbering_engine/mix.exs
COPY --chown=app:app apps/gibbering_tales/mix.exs apps/gibbering_tales/mix.exs
COPY --chown=app:app apps/gibbering_tales_web/mix.exs apps/gibbering_tales_web/mix.exs
COPY --chown=app:app apps/gibbering_tales_admin/mix.exs apps/gibbering_tales_admin/mix.exs
RUN mix deps.get
RUN MIX_ENV=dev mix deps.compile
RUN MIX_ENV=test mix deps.compile

COPY --chown=app:app . .

CMD ["mix", "phx.server"]
