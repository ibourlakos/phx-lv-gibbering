FROM elixir:1.18.4-otp-27-alpine

RUN apk add --no-cache \
    build-base \
    git \
    nodejs \
    npm \
    inotify-tools

RUN addgroup -S -g 1000 app && adduser -S -u 1000 -G app app

RUN mix local.hex --force && mix local.rebar --force

WORKDIR /app
RUN chown app:app /app

USER app

# Deps cached separately from source so rebuilds are fast.
# Pre-compile for both dev and test so the build_cache volume is seeded
# with compiled deps on first mount — avoids long recompilation on fresh volumes.
COPY --chown=app:app mix.exs mix.lock ./
RUN mix deps.get
RUN MIX_ENV=dev mix deps.compile
RUN MIX_ENV=test mix deps.compile

COPY --chown=app:app . .

CMD ["mix", "phx.server"]
